{% extends "page.html.twig" %}

{% block title %}Moss Removal in Metro Vancouver BC | Clean Gutters Crew{% endblock %}

{% block content %}
    <section class="moss-section">

        <h1>4. Moss Removal</h1>

        <img style="width: 100%" src="/assets/images/services/Moss.png">

        <h2>Moss Is Not Just a Green Layer</h2>

        <p>
            Moss acts like a sponge. It holds moisture directly against your shingles.
        </p>

        <p>What follows:</p>

        <ul>
            <li>Moisture penetrates under shingles</li>
            <li>Mold develops</li>
            <li>Freeze-thaw expansion lifts shingles</li>
            <li>Micro-fractures form</li>
            <li>Roof leaks begin</li>
        </ul>

        <p>
            In BC’s damp climate, this process accelerates quickly.
        </p>

        <h2>Ignoring Moss Leads To</h2>

        <ul>
            <li>Lifted and damaged shingles</li>
            <li>Reduced roof lifespan</li>
            <li>Wet insulation</li>
            <li>Rotting roof decking</li>
            <li>Debris washing into gutters</li>
        </ul>

        <h2>Financial Reality</h2>

        <p>
            Roof replacement is one of the most expensive home repairs.
        </p>

        <p>
            Moss removal costs a fraction of that.
        </p>

        <h2>Psychological Protection</h2>

        <p>When your roof is maintained:</p>

        <ul>
            <li>You are not worried about heavy rain</li>
            <li>You are not stressed during winter freezes</li>
            <li>You avoid surprise interior damage</li>
        </ul>

        <h2>Table</h2>

        <div class="table-wrapper">
            <table class="service-table">
                <thead>
                <tr>
                    <th>If Ignored</th>
                    <th>What Happens</th>
                    <th>Regular Removal Provides</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Moss retains water</td>
                    <td>Moisture intrusion</td>
                    <td>Dry roofing system</td>
                </tr>
                <tr>
                    <td>Freeze-thaw cycles</td>
                    <td>Shingle lifting</td>
                    <td>Structural stability</td>
                </tr>
                <tr>
                    <td>Organic debris</td>
                    <td>Gutter clogging</td>
                    <td>Clear drainage</td>
                </tr>
                <tr>
                    <td>Persistent dampness</td>
                    <td>Mold &amp; rot</td>
                    <td>Extended roof lifespan</td>
                </tr>
                </tbody>
            </table>
        </div>

    </section>
{% endblock %}

{% block styles %}
    <style>
        .moss-section {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
            background: #ffffff;
            line-height: 1.7;
            font-family: Inter, sans-serif;
        }

        .moss-section h1 {
            font-size: 28px;
            margin-bottom: 20px;
        }

        .moss-section h2 {
            font-size: 20px;
            margin-top: 35px;
            margin-bottom: 15px;
        }

        .moss-section ul {
            padding-left: 20px;
            margin-bottom: 20px;
        }

        .moss-section li {
            margin-bottom: 8px;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-top: 20px;
        }

        .service-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        .service-table thead {
            background: #f4f6f8;
        }

        .service-table th,
        .service-table td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid #e5e7eb;
        }

        .service-table th {
            font-weight: 600;
        }

        .service-table tbody tr:hover {
            background: #fafafa;
        }

        @media (max-width: 768px) {
            .moss-section {
                padding: 25px 15px;
            }

            .moss-section h1 {
                font-size: 22px;
            }

            .moss-section h2 {
                font-size: 18px;
            }
        }
    </style>
{% endblock %}