{% block content %}
    <section class="junk-section">

        <h1>Junk Removal </h1>

        <img style="width: 100%" src="/assets/images/services/Junk.png">

        <h2>Why Choose Us</h2>

        <p>
            We do not just remove junk — we solve the problem completely and professionally.
        </p>

        <ul>
            <li>On-time arrival</li>
            <li>Careful handling — no damage to walls or floors</li>
            <li>Clean finish — nothing left behind</li>
            <li>Responsible disposal and recycling</li>
            <li>Transparent pricing with no surprises</li>
        </ul>

        <p>
            We understand that clutter creates stress. Our job is to remove it quickly and efficiently.
        </p>

        <h2>Why Regular Junk Removal Matters</h2>

        <p>Accumulated junk:</p>

        <ul>
            <li>Creates fire hazards</li>
            <li>Attracts rodents and insects</li>
            <li>Traps moisture and causes mold</li>
            <li>Blocks ventilation</li>
            <li>Increases mental stress</li>
        </ul>

        <p>
            In BC’s damp climate, stored waste deteriorates faster and creates odors.
        </p>

        <h2>What Happens If You Ignore It</h2>

        <ul>
            <li>Pest infestations</li>
            <li>Mold growth</li>
            <li>Injury risks</li>
            <li>Reduced usable space</li>
            <li>Lower property appeal</li>
        </ul>

        <h2>Financial Benefit</h2>

        <p>A clean space:</p>

        <ul>
            <li>Protects stored belongings</li>
            <li>Prevents structural damage</li>
            <li>Increases property value</li>
            <li>Makes resale easier</li>
        </ul>

        <h2>Table</h2>

        <div class="table-wrapper">
            <table class="service-table">
                <thead>
                <tr>
                    <th>If Ignored</th>
                    <th>What Happens</th>
                    <th>Regular Removal Provides</th>
                </tr>
                </thead>
                <tbody>
                <tr>
                    <td>Clutter buildup</td>
                    <td>Fire hazard</td>
                    <td>Safer environment</td>
                </tr>
                <tr>
                    <td>Damp storage</td>
                    <td>Mold &amp; odor</td>
                    <td>Dry, usable space</td>
                </tr>
                <tr>
                    <td>Packed garage</td>
                    <td>Lost functionality</td>
                    <td>Organized storage</td>
                </tr>
                <tr>
                    <td>Organic waste</td>
                    <td>Pest attraction</td>
                    <td>Hygienic conditions</td>
                </tr>
                </tbody>
            </table>
        </div>

    </section>
{% endblock %}

{% block styles %}
    <style>
        .junk-section {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px;
            background: #ffffff;
            line-height: 1.7;
            font-family: 'Inter', sans-serif;
        }

        .junk-section h1 {
            font-size: 28px;
            margin-bottom: 20px;
            font-family: 'Poppins', sans-serif;
        }

        .junk-section h2 {
            font-size: 20px;
            margin-top: 35px;
            margin-bottom: 15px;
            font-family: 'Poppins', sans-serif;
        }

        .junk-section ul {
            padding-left: 20px;
            margin-bottom: 20px;
        }

        .junk-section li {
            margin-bottom: 8px;
        }

        .table-wrapper {
            overflow-x: auto;
            margin-top: 20px;
        }

        .service-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 600px;
        }

        .service-table thead {
            background: #f4f6f8;
        }

        .service-table th,
        .service-table td {
            padding: 14px 16px;
            text-align: left;
            border-bottom: 1px solid #e5e7eb;
        }

        .service-table th {
            font-weight: 600;
            font-family: 'Poppins', sans-serif;
        }

        .service-table tbody tr:hover {
            background: #fafafa;
        }

        @media (max-width: 768px) {
            .junk-section {
                padding: 25px 15px;
            }

            .junk-section h1 {
                font-size: 22px;
            }

            .junk-section h2 {
                font-size: 18px;
            }
        }
    </style>
{% endblock %}