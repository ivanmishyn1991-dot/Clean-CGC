<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
    <!-- Meta Pixel Code -->
    <script>
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init', '4371677243055821');
    fbq('track', 'PageView');
    </script>
    <noscript><img height="1" width="1" style="display:none"
    src="https://www.facebook.com/tr?id=4371677243055821&ev=PageView&noscript=1"
    /></noscript>
    <!-- End Meta Pixel Code -->
    <title>{% block title %}{% endblock %}</title>
    <meta name="description" content="Gutter cleaning, window washing, moss removal and more services in Metro Vancouver"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@600;700&display=swap" rel="stylesheet">

    <!-- Robot icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    {% block styles %}{% endblock %}


    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <!-- Schema.org для локального бизнеса -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "LocalBusiness",
            "name": "Clean Gutters Crew",
            "telephone": "+16725006060",
            "email": "cgc.services.bc@gmail.com",
            "address": {
                "@type": "PostalAddress",
                "addressRegion": "BC",
                "addressCountry": "CA"
            },
            "areaServed": "Metro Vancouver",

            "priceRange": "$$",
            "openingHours": "Mo-Su 07:00-20:00"
        }
    </script>


    <link rel="stylesheet" type="text/css" href="/assets/css/page-city.css">
    <!-- Modals styles (shared with main page) -->
    <link rel="stylesheet" type="text/css" href="/assets/css/main-page.css">
</head>
<body>
<div id="bg-robots"></div>

{% include 'landing/components/header.html.twig' %}

<main>
    <section id="city">
        <div class="container">
            <aside class="side-panel left side-services" aria-label="Services panel">
                <div class="side-card">
                    <button class="services-acc-btn" id="servicesAccBtn" type="button" aria-expanded="false" aria-controls="servicesAccPanel">
                        <span class="label"><span class="dot"></span>Our services</span>
                        <span class="chev">⌄</span>
                    </button>

                    <div class="services-acc-panel" id="servicesAccPanel" aria-label="Services list">
                        <div class="services-links" aria-label="Services (links to main site services section)">
                            <a class="service-link" href="/services/gutter_cleaning">Gutter Cleaning</a>
                            <a class="service-link" href="/services/window_washing">Window Washing</a>
                            <a class="service-link" href="/services/pressure_washing">Pressure Washing</a>
                            <a class="service-link" href="/services/moss_removal">Moss Removal</a>
                            <a class="service-link" href="/services/junk_removal">Junk Removal</a>
                            <a class="service-link" href="/services/handyman_services">Handyman Services</a>
                        </div>
                    </div>

                    <a class="btn-primary side-quote" href="/#quote">Get a Quote</a>
                </div>
                
                <!-- CTA Buttons (PC only) - под сайдбаром -->
                <div class="side-cta-buttons" id="sideCTAButtons">
                    <button class="side-btn-callback" id="sideCallMeBack" type="button">
                        <i class="fa-solid fa-phone"></i> Call me back
                    </button>
                    <button class="side-btn-price" id="sidePriceBtn" type="button">
                        <i class="fa-solid fa-tag"></i> Price
                    </button>
                </div>
            </aside>

            <!-- RIGHT: fixed work photos -->
            <aside class="side-panel right side-work" aria-label="Work photos panel">
                <div class="side-card">
                    <div style="font-family:'Poppins',sans-serif; font-size:1.05rem; font-weight:900; color:var(--gray-8); margin-bottom:12px; text-align:left;">
                        Before and after
                    </div>

                    <div class="work-grid">
                        {% for photo in get_work_photos(4) %}
                        <div class="work-tile">
                            <button class="work-open" type="button" aria-label="Open photo">
                                <img class="work-photo" src="{{ photo.url }}" alt="{{ photo.alt }}" loading="lazy">
                            </button>
                        </div>
                        {% endfor %}
                    </div>

                    <div class="work-note">
                        If you want to see more photos of our work, visit our
                        <a href="https://facebook.com/YOUR_PAGE" target="_blank" rel="noopener">Facebook</a>.
                    </div>
                </div>
            </aside>

            <div class="seo-card">
                <article class="article-doc">
                    {% block content %}{% endblock %}
                </article>
            </div>

            <div class="seo-cta-outside">
               <a href="/#quote" class="quote-btn">Get a quote in 1 minute</a>
            </div>

        </div>
    </section>
</main>

<footer role="contentinfo" aria-label="Site footer">
    <div class="container">
        <div style="max-width:980px; margin:0 auto;">
            <div style="font-family:'Poppins',sans-serif; font-size:2.1rem; line-height:1.1; font-weight:800; color:#fff;">
                Clean Gutters Crew
            </div>

            <p style="margin:18px 0 18px; font-size:1.06rem; color:rgba(255,255,255,0.92); font-weight:700;">
                Local exterior cleaning for Metro Vancouver homeowners
            </p>

            <p style="font-size:1.06rem; line-height:1.7; color:rgba(255,255,255,0.92); font-weight:700;">
                Phone:
                <a href="tel:+16725006060">+1 (672) 500-6060</a>
                <span style="opacity:0.75;">•</span>
                Text:
                <a href="sms:+16725006060">SMS +1 (672) 500-6060</a>
                <span style="opacity:0.75;">•</span>
                Email:
                <a href="mailto:cgc.services.bc@gmail.com">cgc.services.bc@gmail.com</a>
            </p>

            <p style="margin-top:16px; font-size:1.02rem; line-height:1.7; color:rgba(255,255,255,0.90); font-weight:700;">
                Service area: Metro Vancouver, BC, Canada<br>
                Hours: Mon–Sun 7:00am–8:00pm<br>
                Fully insured
            </p>

            <div style="margin-top:26px; display:flex; gap:14px; justify-content:center; flex-wrap:wrap;">
                <a href="/docs/privacy" style="color:var(--accent); font-weight:900; text-decoration:none;">Privacy Policy</a>
                <span style="color:rgba(255,255,255,0.55);">•</span>
                <a href="/docs/terms" style="color:var(--accent); font-weight:900; text-decoration:none;">Terms of Service</a>
                <span style="color:rgba(255,255,255,0.55);">•</span>
                <a href="#quote" data-page-link="quote" style="color:var(--accent); font-weight:900; text-decoration:none;">Get a Quote</a>
            </div>

            <p style="margin-top:42px; color:rgba(203,213,225,0.95); font-size:0.98rem; font-weight:700;">
                © 2026 Clean Gutters Crew. All rights reserved.
            </p>
        </div>
    </div>
</footer>

<div class="photo-modal" id="photoModal" aria-hidden="true">
    <div class="photo-modal-inner" role="dialog" aria-modal="true" aria-label="Photo preview">
        <button class="photo-modal-close" id="photoModalClose" type="button" aria-label="Close">✕</button>
        <img class="photo-modal-img" id="photoModalImg" src="" alt="Photo preview">
    </div>
</div>


<!-- CGC Robot (inserted into main file) -->
<div class="cgc-robot-wrap" id="cgcRobotWrap" aria-label="CGC Robot contact widget">
    <div class="cgc-social-panel" aria-label="Quick contacts">
        <a class="cgc-social-item fb" href="https://www.facebook.com/profile.php?id=61587613647830" target="_blank" rel="noopener" aria-label="Facebook">
            <i class="fa-brands fa-facebook-f"></i>
        </a>

        <a class="cgc-social-item ig" href="https://www.instagram.com/cgcservices.ca/" target="_blank" rel="noopener" aria-label="Instagram">
            <i class="fa-brands fa-instagram"></i>
        </a>

        <a class="cgc-social-item wa" href="https://wa.me/16725006060" target="_blank" rel="noopener" aria-label="WhatsApp">
            <i class="fa-brands fa-whatsapp"></i>
        </a>

        <a class="cgc-social-item tg" href="https://t.me/CGC_services" target="_blank" rel="noopener" aria-label="Telegram">
            <i class="fa-brands fa-telegram"></i>
        </a>
    </div>

    <button class="cgc-robot-btn" id="cgcRobotBtn" type="button" aria-expanded="false" aria-label="Open contacts">
        <img
                class="cgc-robot-img"
                src="/assets/images/social-robot.png"
                alt="CGC Robot"
        />
        <div class="cgc-robot-bubble" id="cgcRobotBubble">Tap me</div>
    </button>
    <button class="cgc-robot-hit" id="cgcRobotHit" type="button" aria-label="Open contacts"></button>
</div>

<!-- Photo Lightbox -->
<div class="photo-lightbox" id="photoLightbox" aria-hidden="true">
    <div class="photo-lightbox-content">
        <button class="photo-lightbox-close" type="button" aria-label="Close">&times;</button>
        <button class="photo-lightbox-nav photo-lightbox-prev" type="button" aria-label="Previous">&#8249;</button>
        <img class="photo-lightbox-img" id="lightboxImg" src="" alt="">
        <button class="photo-lightbox-nav photo-lightbox-next" type="button" aria-label="Next">&#8250;</button>
        <div class="photo-lightbox-caption" id="lightboxCaption"></div>
    </div>
</div>

<!-- Sticky Bottom Bar (Mobile Only - Services/Cities pages) -->
<div class="sticky-bottom-bar" id="stickyBottomBar">
    <button class="sticky-btn-main" id="stickyMenuBtn" type="button" aria-label="Open services menu">
        <span>Our Services</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>
</div>

<!-- Sticky Menu Overlay -->
<div class="sticky-menu-overlay" id="stickyMenuOverlay"></div>

<!-- Sticky Slide-up Menu -->
<div class="sticky-menu" id="stickyMenu">
    <div class="sticky-menu-handle"></div>
    
    <div class="sticky-menu-grid">
        <!-- Call me back -->
        <button class="sticky-menu-item highlight" id="stickyCallMeBack" type="button">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-phone"></i>
            </div>
            <div class="sticky-menu-text">
                Call me back
                <span>We'll call you in 15 min</span>
            </div>
        </button>
        
        <div class="sticky-menu-divider"></div>
        
        <!-- Services with prices -->
        <a class="sticky-menu-item" href="/services/gutter_cleaning">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-house-chimney"></i>
            </div>
            <div class="sticky-menu-text">
                Gutter Cleaning
                <span class="sticky-price">from $150</span>
            </div>
        </a>
        
        <a class="sticky-menu-item" href="/services/window_washing">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-window-maximize"></i>
            </div>
            <div class="sticky-menu-text">
                Window Washing
                <span class="sticky-price">from $150</span>
            </div>
        </a>
        
        <a class="sticky-menu-item" href="/services/pressure_washing">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-spray-can-sparkles"></i>
            </div>
            <div class="sticky-menu-text">
                Pressure Washing
                <span class="sticky-price">from $200</span>
            </div>
        </a>
        
        <a class="sticky-menu-item" href="/services/moss_removal">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-leaf"></i>
            </div>
            <div class="sticky-menu-text">
                Moss Removal
                <span class="sticky-price">from $400</span>
            </div>
        </a>
        
        <div class="sticky-menu-divider"></div>
        
        <!-- Get Quote - Orange button -->
        <a class="sticky-menu-item sticky-quote-btn" href="/#quote">
            <div class="sticky-menu-icon">
                <i class="fa-solid fa-calculator"></i>
            </div>
            <div class="sticky-menu-text">
                Get Your Price
                <span>Free estimate</span>
            </div>
        </a>
    </div>
</div>

<!-- Quick Quote Modal (same as main page) -->
<div class="quick-quote-overlay" id="quickQuoteOverlay">
    <div class="quick-quote-modal" id="quickQuoteModal">
        <button class="quick-quote-close" id="quickQuoteClose" type="button" aria-label="Close">&times;</button>
        <h3 class="quick-quote-title">Quick callback request</h3>
        <p class="quick-quote-subtitle">Leave your number and we'll call you back shortly</p>

        <form id="quickQuoteForm" class="quick-quote-form">
            {{ csrf_field() }}
            <div class="quick-quote-input-wrap">
                <input type="tel" id="quickPhone" name="phone" placeholder="Your phone number" required pattern="^[0-9+\s()-]{10,20}$" autocomplete="tel">
            </div>

            <div class="quick-quote-buttons">
                <button type="submit" class="btn-quick btn-quick-submit" id="btnQuickSubmit">
                    <span class="btn-quick-text">Send</span>
                    <span class="btn-quick-success" style="display:none;">✓</span>
                </button>
                <a href="https://wa.me/16725006060" target="_blank" rel="noopener" class="btn-quick btn-quick-whatsapp">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                </a>
            </div>
        </form>

        <div class="quick-quote-success" id="quickQuoteSuccess" style="display:none;">
            <div class="success-checkmark">✓</div>
            <p class="success-message">We'll contact you shortly</p>
        </div>
    </div>
</div>

<!-- Price Modal -->
<div class="price-modal-overlay" id="priceModalOverlay">
    <div class="price-modal" id="priceModal">
        <button class="price-modal-close" id="priceModalClose" type="button" aria-label="Close">&times;</button>
        <h3 class="price-modal-title">Our Pricing</h3>
        
        <ul class="price-list">
            <li class="price-list-item">Minimum service call <span>$120</span></li>
            <li class="price-list-item">Gutter Cleaning <span>from $150</span></li>
            <li class="price-list-item">Window Washing <span>from $150</span></li>
            <li class="price-list-item">Pressure Washing <span>from $200</span></li>
            <li class="price-list-item">Moss Removal <span>from $400</span></li>
            <li class="price-list-item">Junk Removal <span>from $150</span></li>
            <li class="price-list-item">Handyman Services <span>from $120</span></li>
        </ul>
        
        <p class="price-note">Call us today to find out what special offers and discounts are available.</p>
        
        <div class="price-buttons">
            <button class="price-btn price-btn-callback" id="priceCallMeBack" type="button">
                <i class="fa-solid fa-phone"></i> Call me back
            </button>
            <a class="price-btn price-btn-call" href="tel:+16725006060">
                <i class="fa-solid fa-phone-volume"></i> Call now
            </a>
            <a class="price-btn price-btn-quote" href="/#quote" data-page-link="quote">
                <i class="fa-solid fa-file-lines"></i> Get your price in a minute
            </a>
        </div>
    </div>
</div>

<script src="/assets/js/page-city.js?rand={{ random() }}"></script>



</body>
</html>