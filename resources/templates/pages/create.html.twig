{% extends "dashboard.html.twig" %}

{% block title %}Applications list{% endblock %}

{% block content %}
    <div class="row tm-mt-big">
        <div class="col-12">
            <div class="bg-white tm-block">
                <div class="row">
                    <div class="col-12">
                        <h2 class="tm-block-title d-inline-block">Создание страницы</h2>
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-xl-8 col-lg-8 col-md-12">
                        <form action="" method="POST">
                            <div class="input-group mb-3">
                                <label for="page-route" class="col-xl-4 col-lg-4 col-md-4 col-sm-5 col-form-label">Маршрут (Route)</label>
                                <input placeholder="например: /about" id="page-route" name="route" type="text" class="form-control validate col-xl-9 col-lg-8 col-md-8 col-sm-7">
                            </div>

                            <div class="input-group mb-3">
                                <label for="page-title" class="col-xl-4 col-lg-4 col-md-4 col-sm-5 col-form-label">Заголовок</label>
                                <input placeholder="Заголовок страницы" id="page-title" name="title" type="text" class="form-control validate col-xl-9 col-lg-8 col-md-8 col-sm-7">
                            </div>

                            <div class="input-group mb-3 quill-editor-container">
                                <label class="col-xl-4 col-lg-4 col-md-4 col-sm-5 mb-2">Содержимое страницы</label>
                                <div class="col-xl-8 col-lg-8 col-md-8 col-sm-7 px-0">
                                    <!-- Контейнер для Quill редактора -->
                                    <div id="quill-editor"></div>
                                    <!-- Скрытое поле для отправки данных формы -->
                                    <textarea id="page-content" name="content" style="display:none;"></textarea>
                                </div>
                            </div>

                            <div class="input-group mb-3">
                                <div class="ml-auto col-xl-8 col-lg-8 col-md-8 col-sm-7 pl-0">
                                    <button type="submit" class="btn btn-primary">Создать страницу</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block styles %}
    <!-- Подключаем CSS Quill редактора -->
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <style>
        /* Дополнительные стили для редактора */
        .quill-editor-container {
            margin-bottom: 20px;
        }
        #quill-editor {
            height: 400px;
            background: white;
            border-radius: 0 0 4px 4px;
        }
        .ql-toolbar {
            border-radius: 4px 4px 0 0;
            background: #f8f9fa;
        }
    </style>
{% endblock %}

{% block scripts %}
    <!-- Подключаем JavaScript Quill редактора -->
    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

    <script type="text/javascript">
        $(document).ready(function() {
            // Инициализация Quill редактора
            var quill = new Quill('#quill-editor', {
                theme: 'snow',
                placeholder: 'Введите содержимое страницы...',
                modules: {
                    toolbar: [
                        [{ 'header': [1, 2, 3, 4, 5, 6, false] }], // Заголовки
                        ['bold', 'italic', 'underline', 'strike'], // Форматирование текста
                        [{ 'list': 'ordered'}, { 'list': 'bullet' }], // Списки
                        [{ 'script': 'sub'}, { 'script': 'super' }], // Верхний/нижний индекс
                        [{ 'indent': '-1'}, { 'indent': '+1' }], // Отступы
                        [{ 'color': [] }, { 'background': [] }], // Цвет текста и фона
                        ['link', 'image', 'video'], // Вставка ссылок, изображений, видео
                        ['clean'] // Очистка форматирования
                    ]
                }
            });

            // При отправке формы копируем содержимое редактора в скрытое поле
            $('form').on('submit', function() {
                var content = quill.root.innerHTML;
                $('#page-content').val(content);

                // Можно добавить отладку в консоль
                console.log('Отправляем содержимое:', content);
            });

            // Если нужно загрузить существующий контент (например, при редактировании)
            // Раскомментируйте следующую строку и укажите нужный HTML
            // quill.root.innerHTML = '<p>Существующий контент</p>';
        });

        // Ваша существующая функция для AJAX запросов
        function create(id)
        {
            // Получаем содержимое редактора
            var content = quill.root.innerHTML;

            $.ajax({
                type: 'POST',
                url: '/admin/pages/'+id,
                data: {
                    content: content,
                    // добавьте другие поля формы
                },
                dataType: 'json',
                cache: false,
                success: function (response) {
                    console.log('Успешно сохранено:', response);
                    // Можно добавить уведомление об успехе
                    alert('Страница успешно создана!');
                },
                error: function(xhr, status, error) {
                    console.error('Ошибка:', error);
                    alert('Произошла ошибка при сохранении');
                }
            });
        }
    </script>
{% endblock %}