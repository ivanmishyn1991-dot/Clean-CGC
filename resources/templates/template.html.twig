{% block scripts %}
    <script src="/assets/js/app.min.js?rand={{ random() }}"></script>
    
    <!-- Deferred Facebook Pixel - loads after page is ready -->
    <script>
    window.addEventListener('load', function() {
        // Load Facebook Pixel only after user interaction or 5 seconds
        var fbLoaded = false;
        function loadFBPixel() {
            if (fbLoaded) return;
            fbLoaded = true;
            !function(f,b,e,v,n,t,s)
            {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
                n.callMethod.apply(n,arguments):n.queue.push(arguments)};
                if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
                n.queue=[];t=b.createElement(e);t.async=!0;
                t.src=v;s=b.getElementsByTagName(e)[0];
                s.parentNode.insertBefore(t,s)}(window, document,'script',
                'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '4371677243055821');
            fbq('track', 'PageView');
        }
        // Load on first interaction or after 5 seconds
        ['scroll', 'click', 'touchstart', 'mousemove'].forEach(function(e) {
            document.addEventListener(e, loadFBPixel, {once: true, passive: true});
        });
        setTimeout(loadFBPixel, 5000);
    });
    </script>
    
    <!-- Lazy load reCAPTCHA only when quote form is visible -->
    <script>
    (function() {
        var recaptchaLoaded = false;
        function loadRecaptcha() {
            if (recaptchaLoaded) return;
            recaptchaLoaded = true;
            var script = document.createElement('script');
            script.src = 'https://www.google.com/recaptcha/api.js';
            script.async = true;
            script.defer = true;
            document.head.appendChild(script);
        }
        
        // Load when user clicks quote link or interacts with form
        var quoteLinks = document.querySelectorAll('[data-page-link="quote"], [href="#quote"], [href="/#quote"]');
        quoteLinks.forEach(function(link) {
            link.addEventListener('click', loadRecaptcha);
        });
        
        // Load when user interacts with any form input
        document.addEventListener('focusin', function(e) {
            if (e.target.matches('input, textarea, select')) {
                loadRecaptcha();
            }
        }, { once: true });
        
        // Load on scroll only when quote section is about to be visible
        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    loadRecaptcha();
                    observer.disconnect();
                }
            });
        }, { rootMargin: '100px' });
        
        var quotePage = document.getElementById('quotePage');
        if (quotePage) observer.observe(quotePage);
        
        // Also observe the g-recaptcha element directly
        var recaptchaEl = document.querySelector('.g-recaptcha');
        if (recaptchaEl) observer.observe(recaptchaEl);
        
        // NO automatic fallback - only load when user needs it
    })();
    </script>
