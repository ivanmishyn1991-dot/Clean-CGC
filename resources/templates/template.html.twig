    <!-- AEO: Schema.org FAQPage -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "How long does gutter cleaning take?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Usually 1–4 hours depending on the home size, number of stories, and how clogged the gutters are. If you share a couple photos, we can estimate more accurately."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do I need to be home during the service?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "No. As long as we can access the work areas (for example, gates unlocked), you don't have to be home. We clean carefully and leave the area tidy."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How often should gutters be cleaned here?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Most homes need 1–2 times per year (spring and fall). If you have many trees nearby, twice a year is best to prevent overflows during heavy rain."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Are you insured?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. We're fully insured. If you need confirmation for peace of mind, we can provide details when you request your quote."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How much does gutter cleaning cost?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Single-story homes often start around $180–250. Price depends on roof size, number of stories, access, and any add-ons. We confirm the total price before we begin."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do you work in rain or winter?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "We avoid heavy rain or snow for safety and to prevent mess. In winter, we usually work on dry days and above-freezing temperatures."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do you clean windows inside and outside?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. We can do exterior-only or both interior and exterior. We can also include sliding doors and sills if agreed in advance."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Is roof moss removal safe for my roof?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. We use safe methods and avoid harsh approaches that damage shingles. When possible, we minimize roof foot traffic."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Do you provide before/after photos?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, on request. Many homeowners love photo proof, especially for gutters and roof work, so you can clearly see the result."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How do bookings and payments work?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Request a quote or call us. We confirm the price and schedule. Payment is after the job (cash, e-Transfer, or card). No deposit required."
                    }
                }
            ]
        }
    </script>

