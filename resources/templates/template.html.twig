    <!-- AEO: Additional styles for hero and answer grid -->
    <style>
        .aeo-hero {
            padding: 48px 0 10px;
        }
        .aeo-hero h1 {
            margin: 0 0 16px;
            font-family: 'Poppins', sans-serif;
            font-size: clamp(2rem, 4vw, 3.5rem);
            line-height: 1.08;
            background: linear-gradient(90deg, var(--primary), var(--accent));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .aeo-hero .hero-lead {
            max-width: 920px;
            font-size: 1.08rem;
            line-height: 1.75;
            color: #334155;
            margin: 0 auto 22px;
            text-align: center;
        }
        .aeo-hero .hero-points {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            justify-content: center;
            margin-top: 22px;
            max-width: 980px;
            margin-left: auto;
            margin-right: auto;
            background: rgba(255,255,255,0.88);
            border: 1px solid rgba(2,132,199,0.18);
            border-radius: 999px;
            box-shadow: 0 4px 12px rgba(2,132,199,0.08);
            padding: 12px 14px;
            backdrop-filter: blur(8px);
        }
        .aeo-hero .hero-point {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: white;
            border: 1px solid rgba(56,189,248,0.55);
            color: var(--gray-8);
            padding: 10px 14px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 0.98rem;
            box-shadow: 0 10px 24px rgba(2,132,199,0.10);
            white-space: nowrap;
            transition: all 0.3s ease;
            cursor: default;
        }
        .aeo-hero .hero-point::before {
            content: "";
            width: 10px;
            height: 10px;
            border-radius: 99px;
            background: linear-gradient(90deg, var(--primary), var(--primary-l));
            box-shadow: 0 0 0 5px rgba(2,132,199,0.10);
            flex-shrink: 0;
        }
        .aeo-hero .hero-point:hover {
            box-shadow: 0 10px 30px rgba(2,132,199,0.25), 0 0 15px rgba(56,189,248,0.3);
            transform: translateY(-2px);
        }
        
        /* Mobile hero-points grid 2x2 */
        @media (max-width: 768px) {
            .aeo-hero .hero-points {
                display: grid;
                grid-template-columns: 1fr 1fr;
                gap: 10px;
                border-radius: 24px;
                padding: 16px;
            }
            .aeo-hero .hero-point {
                display: flex;
                justify-content: center;
                align-items: center;
                white-space: nowrap;
                text-align: center;
                font-size: 0.85rem;
                padding: 10px 8px;
                width: 100%;
                box-sizing: border-box;
            }
        }
        
        .answer-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 20px;
            margin-top: 32px;
        }
        .answer-card {
            background: #fff;
            border: 1px solid transparent;
            border-radius: var(--radius);
            padding: 28px 24px;
            box-shadow: 0 4px 12px rgba(2,132,199,0.08);
            transition: all 0.38s ease;
            cursor: default;
        }
        .answer-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 30px rgba(2,132,199,0.14);
            border-color: var(--accent);
        }
        .answer-card h3 {
            margin: 0 0 12px;
            font-size: 1.3rem;
            color: var(--primary);
            font-weight: 700;
        }
        .answer-card p {
            margin: 0;
            line-height: 1.75;
            color: var(--gray-6);
        }
        .answer-card h4 {
            margin: 0 0 12px;
            font-size: 1.2rem;
            color: var(--primary);
            font-weight: 700;
        }
        .include-list {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-top: 20px;
        }
        .include-item {
            background: #fff;
            border: 1px solid transparent;
            padding: 18px 20px;
            border-radius: var(--radius);
            line-height: 1.6;
            color: var(--gray-6);
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(2,132,199,0.08);
            transition: all 0.38s ease;
            cursor: default;
        }
        .include-item:hover {
            transform: translateY(-6px);
            box-shadow: 0 10px 30px rgba(2,132,199,0.14);
            border-color: var(--accent);
        }
        @media (max-width: 860px) {
            .answer-grid,
            .include-list {
                grid-template-columns: 1fr;
            }
            .aeo-hero {
                padding: 32px 0 10px;
            }
            .aeo-hero h1 {
                font-size: 1.75rem;
            }
            .aeo-hero .hero-lead {
                font-size: 1rem;
            }
        }

        /* Photo Upload Styles */
        .photo-upload-group {
            margin-top: 8px;
        }
        .field-hint {
            font-size: 0.9rem;
            color: #64748b;
            margin: 4px 0 12px;
        }
        .photo-upload-zone {
            border: 2px dashed #cbd5e1;
            border-radius: 16px;
            padding: 32px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s ease;
            background: #f8fafc;
        }
        .photo-upload-zone:hover,
        .photo-upload-zone.dragover {
            border-color: var(--primary);
            background: #eff6ff;
        }
        .photo-upload-zone .upload-icon {
            color: #94a3b8;
            margin-bottom: 12px;
        }
        .photo-upload-zone:hover .upload-icon {
            color: var(--primary);
        }
        .upload-text {
            font-size: 1rem;
            color: #334155;
            margin: 0 0 8px;
        }
        .upload-link {
            color: var(--primary);
            font-weight: 600;
            text-decoration: underline;
        }
        .upload-formats {
            font-size: 0.85rem;
            color: #94a3b8;
            margin: 0;
        }
        .photo-preview-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 12px;
            margin-top: 16px;
        }
        .photo-preview-item {
            position: relative;
            aspect-ratio: 1;
            border-radius: 12px;
            overflow: hidden;
            background: #f1f5f9;
        }
        .photo-preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .photo-preview-item .remove-photo {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 24px;
            height: 24px;
            background: rgba(0,0,0,0.6);
            border: none;
            border-radius: 50%;
            color: #fff;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            line-height: 1;
            transition: background 0.2s;
        }
        .photo-preview-item .remove-photo:hover {
            background: #ef4444;
        }
        .photo-preview-item.uploading::after {
            content: '';
            position: absolute;
            inset: 0;
            background: rgba(255,255,255,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .photo-preview-item .upload-spinner {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 24px;
            height: 24px;
            border: 3px solid #e2e8f0;
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }
        .upload-progress {
            margin-top: 12px;
        }
        .progress-bar {
            height: 6px;
            background: #e2e8f0;
            border-radius: 3px;
            overflow: hidden;
        }
        .progress-fill {
            height: 100%;
            background: var(--primary);
            width: 0%;
            transition: width 0.3s ease;
        }
        .progress-text {
            display: block;
            font-size: 0.85rem;
            color: #64748b;
            margin-top: 6px;
            text-align: center;
        }
        .photo-preview-item.error {
            border: 2px solid #ef4444;
        }
        .photo-preview-item .error-badge {
            position: absolute;
            bottom: 6px;
            left: 6px;
            right: 6px;
            background: #ef4444;
            color: #fff;
            font-size: 0.7rem;
            padding: 2px 6px;
            border-radius: 4px;
            text-align: center;
        }

        /* Quick Quote Styles */
        .btn-callback {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: #fff;
            border: none;
            padding: 16px 40px;
            font-size: 1.15rem;
            font-weight: 700;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(34, 197, 94, 0.4);
            animation: softGlow 2s ease-in-out infinite;
        }
        .btn-callback:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(34, 197, 94, 0.5);
        }
        .btn-callback:active {
            transform: translateY(-1px);
        }
        @keyframes softGlow {
            0%, 100% { box-shadow: 0 4px 20px rgba(34, 197, 94, 0.4); }
            50% { box-shadow: 0 4px 30px rgba(34, 197, 94, 0.6); }
        }

        .quick-quote-overlay {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            height: 100dvh !important;
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            z-index: 999999 !important;
            display: none;
            overflow: hidden;
        }
        .quick-quote-overlay.open {
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
        }
        .quick-quote-modal {
            position: relative !important;
            top: auto !important;
            left: auto !important;
            transform: none !important;
            background: #fff;
            border-radius: 24px;
            padding: 36px 32px;
            max-width: 420px;
            width: calc(100% - 40px);
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.4);
            animation: modalFadeIn 0.3s ease;
            z-index: 1000000 !important;
            max-height: 90vh;
            overflow-y: auto;
        }
        @keyframes modalFadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .quick-quote-close {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 36px;
            height: 36px;
            background: #f1f5f9;
            border: none;
            border-radius: 50%;
            font-size: 24px;
            line-height: 1;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
        }
        .quick-quote-close:hover {
            background: #e2e8f0;
            color: #334155;
        }
        .quick-quote-title {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            margin: 0 0 8px;
            text-align: center;
        }
        .quick-quote-subtitle {
            font-size: 0.95rem;
            color: #64748b;
            margin: 0 0 24px;
            text-align: center;
        }
        .quick-quote-input-wrap {
            margin-bottom: 20px;
        }
        .quick-quote-input-wrap input {
            width: 100%;
            padding: 16px 20px;
            font-size: 1.1rem;
            border: 2px solid #e2e8f0;
            border-radius: 14px;
            outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .quick-quote-input-wrap input:focus {
            border-color: #22c55e;
            box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.1);
        }
        .quick-quote-buttons {
            display: flex;
            gap: 12px;
        }
        .btn-quick {
            flex: 1;
            padding: 14px 20px;
            font-size: 1rem;
            font-weight: 700;
            border: none;
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: all 0.3s ease;
            text-decoration: none;
            animation: softGlow 2s ease-in-out infinite;
        }
        .btn-quick-submit {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: #fff;
            box-shadow: 0 4px 15px rgba(34, 197, 94, 0.4);
        }
        .btn-quick-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(34, 197, 94, 0.5);
        }
        .btn-quick-submit:active {
            transform: translateY(-1px);
        }
        .btn-quick-whatsapp {
            background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
            color: #fff;
            box-shadow: 0 4px 15px rgba(37, 211, 102, 0.4);
        }
        .btn-quick-whatsapp:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.5);
        }
        .btn-quick-whatsapp:active {
            transform: translateY(-1px);
        }
        .quick-quote-success {
            text-align: center;
            padding: 20px 0;
        }
        .success-checkmark {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 36px;
            color: #fff;
            margin: 0 auto 16px;
            animation: checkmarkPop 0.4s ease;
        }
        @keyframes checkmarkPop {
            0% { transform: scale(0); }
            50% { transform: scale(1.2); }
            100% { transform: scale(1); }
        }
        .success-message {
            font-size: 1.1rem;
            color: #334155;
            font-weight: 600;
            margin: 0;
        }

        @media (max-width: 480px) {
            .quick-quote-modal {
                padding: 28px 20px;
                border-radius: 20px;
                width: calc(100% - 32px);
                max-height: 85vh;
            }
            .quick-quote-buttons {
                flex-direction: column;
            }
            .quick-quote-title {
                font-size: 1.3rem;
            }
            .quick-quote-input-wrap input {
                font-size: 16px; /* prevents iOS zoom */
                padding: 14px 16px;
            }
            .btn-callback {
                padding: 14px 28px;
                font-size: 1rem;
            }
        }
        
        /* ========================================
           STICKY BOTTOM BAR (Mobile Only)
        ======================================== */
        .sticky-bottom-bar {
            display: none;
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            z-index: 99998;
            padding: 12px 16px;
            padding-bottom: calc(12px + env(safe-area-inset-bottom));
            background: linear-gradient(to top, rgba(255,255,255,0.98) 0%, rgba(255,255,255,0.95) 100%);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 0 -4px 30px rgba(0,0,0,0.1);
            border-top: 1px solid rgba(34, 197, 94, 0.2);
        }
        
        @media (max-width: 768px) {
            .sticky-bottom-bar {
                display: block;
            }
            body {
                padding-bottom: 80px;
            }
        }
        
        .sticky-btn-main {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
            padding: 16px 24px;
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            color: #fff;
            border: none;
            border-radius: 16px;
            font-size: 1.1rem;
            font-weight: 700;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(34, 197, 94, 0.4);
            transition: all 0.3s ease;
            font-family: inherit;
        }
        
        .sticky-btn-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(34, 197, 94, 0.5);
        }
        
        .sticky-btn-main svg {
            width: 20px;
            height: 20px;
            transition: transform 0.3s ease;
        }
        
        .sticky-btn-main.open svg {
            transform: rotate(180deg);
        }
        
        /* Slide-up Menu */
        .sticky-menu-overlay {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            z-index: 99997;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }
        
        .sticky-menu-overlay.open {
            opacity: 1;
            visibility: visible;
        }
        
        .sticky-menu {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #fff;
            border-radius: 24px 24px 0 0;
            padding: 24px 20px;
            padding-bottom: calc(24px + env(safe-area-inset-bottom));
            z-index: 99999;
            transform: translateY(100%);
            transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
            max-height: 85vh;
            overflow-y: auto;
        }
        
        .sticky-menu.open {
            transform: translateY(0);
        }
        
        .sticky-menu-handle {
            width: 40px;
            height: 4px;
            background: #e2e8f0;
            border-radius: 2px;
            margin: 0 auto 20px;
        }
        
        .sticky-menu-title {
            font-family: 'Poppins', sans-serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
            text-align: center;
            margin: 0 0 20px;
        }
        
        .sticky-menu-grid {
            display: grid;
            gap: 12px;
        }
        
        .sticky-menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            text-decoration: none;
            color: #1e293b;
            font-weight: 600;
            font-size: 1rem;
            transition: all 0.3s ease;
        }
        
        .sticky-menu-item:hover,
        .sticky-menu-item:active {
            background: #eff6ff;
            border-color: var(--primary);
            transform: translateX(4px);
        }
        
        .sticky-menu-item.highlight {
            background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
            border: none;
            color: #fff;
        }
        
        .sticky-menu-item.highlight:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(34, 197, 94, 0.4);
        }
        
        .sticky-menu-icon {
            width: 44px;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fff;
            border-radius: 12px;
            color: var(--primary);
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        
        .sticky-menu-item.highlight .sticky-menu-icon {
            background: rgba(255,255,255,0.2);
            color: #fff;
        }
        
        .sticky-menu-text {
            flex: 1;
        }
        
        .sticky-menu-text span {
            display: block;
            font-size: 0.85rem;
            font-weight: 400;
            color: #64748b;
            margin-top: 2px;
        }
        
        .sticky-menu-item.highlight .sticky-menu-text span {
            color: rgba(255,255,255,0.85);
        }
        
        .sticky-menu-divider {
            height: 1px;
            background: #e2e8f0;
            margin: 8px 0;
        }
        
        .sticky-menu-close {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            padding: 14px;
            margin-top: 16px;
            background: #f1f5f9;
            border: none;
            border-radius: 12px;
            color: #64748b;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-family: inherit;
        }
        
        .sticky-menu-close:hover {
            background: #e2e8f0;
            color: #334155;
        }
    </style>
</head>
<body>
