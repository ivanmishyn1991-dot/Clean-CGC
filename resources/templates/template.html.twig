        .btn-call{background:var(--accent);color:var(--gray-8);padding:18px 44px;font-size:1.12rem;box-shadow:0 6px 18px rgba(251,191,36,.35)}
        .hamburger{display:none;font-size:2.8rem;background:0 0;border:none;cursor:pointer;color:var(--primary)}
        @media(max-width:860px){nav{display:none}.hamburger{display:block}}
        @media(min-width:861px){.header-inner{justify-content:center}header .btn-call,header .btn-email{position:fixed;top:calc(var(--headerH)/2);transform:translateY(-50%);min-width:260px;height:58px;z-index:1001}header .btn-email{left:20px;background:linear-gradient(90deg,var(--primary),var(--primary-l));color:#fff}header .btn-call{right:20px;background:linear-gradient(90deg,var(--primary),var(--primary-l));color:#fff}}
